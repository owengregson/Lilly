# IDE / OS
# ===========================================================================

.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================================================================
# Data (large, re-generated by pipeline)
# ===========================================================================

# Everything under data/ is generated by the pipeline and should not be
# committed (raw ~15 GB, processed Parquet, V3 .npz segments, etc.)
/data/

# ===========================================================================
# Models & Training Artifacts
# ===========================================================================

# Training run directories (checkpoints, logs, eval plots)
models/v3/
models/v2/
models/run_*/

# Keep only the curated best/ directory
!models/best/

# Keras / TensorFlow model weights
*.keras
*.h5
*.savedmodel/
*.pb

# TensorBoard events
*.tfevents*

# Training checkpoints
checkpoint
*.ckpt*
*.index
*.data-00000-of-00001

# ===========================================================================
# Export (TF.js output — root-level only, not lilly/export/)
# ===========================================================================

/export/

# ===========================================================================
# Logs
# ===========================================================================

*.log
logs/

# ===========================================================================
# Jupyter / IPython
# ===========================================================================

.ipynb_checkpoints/
*.ipynb

